# Copy this file to .env and fill in your actual keys
# cp .env.example .env

# ── Active Services ──────────────────────────────────────

# Tracerfy — skip trace ($0.02/match, primary contact enrichment)
# Get from: https://www.tracerfy.com → Dashboard → API
TRACERFY_API_KEY=

# ATTOM Data Solutions — property + mortgage data ($0.019/call)
# Get from: ATTOM developer portal
ATTOM_API_KEY=

# MillionVerifier — email validation ($4.90/2K credits, never expire)
# Get from: https://millionverifier.com → API
MILLIONVERIFIER_API_KEY=

# Twilio — phone type detection ($0.008/lookup, must use v2 API)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Optional / Inactive ─────────────────────────────────

# 2Captcha — CAPTCHA solving for county clerk portals
# TWOCAPTCHA_API_KEY=

# FEC API — wealth signals (free, DEMO_KEY works)
# FEC_API_KEY=DEMO_KEY

# ── Archived (not in active use) ────────────────────────

# Airtable (CRM — archived, may revisit)
# AIRTABLE_API_TOKEN=

# Apollo.io (B2B enrichment — cancelled, returns nothing for RE investors)
# APOLLO_API_KEY=

# Wiza (LinkedIn enrichment — evaluated, not in pipeline)
# WIZA_API_KEY=
