# Copy this file to .env and fill in your actual keys
# cp .env.example .env

# Airtable API Token (Personal Access Token)
# Get from: https://airtable.com/create/tokens
AIRTABLE_API_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Tracerfy API Key (skip trace)
# TRACERFY_API_KEY=your_key_here

# Apollo.io API Key (B2B enrichment)
# APOLLO_API_KEY=your_key_here

# MillionVerifier API Key (email validation)
# MILLIONVERIFIER_API_KEY=your_key_here

# Twilio (phone type detection)
# TWILIO_ACCOUNT_SID=your_sid_here
# TWILIO_AUTH_TOKEN=your_token_here

# Wiza (LinkedIn-based contact enrichment)
# Get from: Wiza Settings → API → Generate
# WIZA_API_KEY=your_key_here

# ATTOM Data Solutions — property + mortgage data
ATTOM_API_KEY=

# 2Captcha — CAPTCHA solving service
TWOCAPTCHA_API_KEY=
