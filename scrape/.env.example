# =============================================================
# DSCR Lead Gen — API Keys & Credentials
# =============================================================
# Copy this file to .env and fill in your actual keys.
# Never commit .env to git — it contains secrets.
# =============================================================

# Apollo.io — primary contact enrichment ($100/mo plan)
# Get your API key: Settings > Integrations > API
# Provides: email, phone, LinkedIn URL, employer, social profiles
APOLLO_API_KEY=your_apollo_api_key_here

# Twilio — phone number validation ($0.005 per lookup)
# Get credentials: console.twilio.com > Account > API Keys
# Provides: carrier name, phone type (mobile/landline/voip), validity
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# MillionVerifier — email validation (~$0.50 per 1,000 emails)
# Get API key: millionverifier.com > Account > API
# Provides: valid/invalid/risky/catch-all status
MILLIONVERIFIER_API_KEY=your_millionverifier_api_key_here

# Numverify — phone type detection (free tier: 100/month)
# Get API key: numverify.com > Dashboard
# Provides: carrier, line type, country
NUMVERIFY_API_KEY=your_numverify_api_key_here

# Tracerfy — skip tracing + DNC scrub
# Sign up at tracerfy.com, generate API key from dashboard
# Skip trace: $0.02/lead (up to 8 phones + 5 emails per lead)
# DNC scrub: $0.02/phone (Federal, State, DMA, TCPA litigator)
# No minimums, no subscriptions, no credit card required to start
TRACERFY_API_KEY=your_tracerfy_api_key_here

# FEC.gov — political donation lookup (free, no key needed for basic)
# Optional API key for higher rate limits: api.open.fec.gov/developers
FEC_API_KEY=DEMO_KEY
