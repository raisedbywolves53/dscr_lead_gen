# Twilio — used in Step 6 (phone validation)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Numverify — used in Step 5/6 (phone number validation, free tier: 100/month)
NUMVERIFY_API_KEY=your_numverify_api_key_here

# MillionVerifier — used in Step 6 (email validation, ~$0.50 per 1,000 emails)
MILLIONVERIFIER_API_KEY=your_millionverifier_api_key_here
